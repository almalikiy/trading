<manifest package="com.example.alertapp" xmlns:android="http://schemas.android.com/apk/res/android">
    <application
        android:label="Trade Alert"
        android:icon="@mipmap/ic_launcher">
        <activity android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <service android:name=".FloatingAlertService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection"/>
        <receiver android:name=".TradeAlertReceiver"/>
    </application>
</manifest>
